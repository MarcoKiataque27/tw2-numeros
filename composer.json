{
    "name": "app/random-generator",
    "description": "PHP OOP application that generates N random numbers",
    "type": "project",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7",
        "friendsofphp/php-cs-fixer": "^3.16"
    },
    "autoload": {
        "psr-4": {
            "App\\Src\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Unit\\": "tests/Unit/"
        }
    },
    "scripts": {
        "lint": "phpcs --standard=PSR12 src/",
        "lint:fix": "phpcbf --standard=PSR12 src/",
        "stan": "phpstan analyse src/ --level=max",
        "stan:baseline": "phpstan analyse src/ --level=max --generate-baseline",
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:coverage": "phpunit --coverage-html coverage",
        "format": "php-cs-fixer fix src/",
        "check": [
            "@lint",
            "@stan",
            "@test"
        ]
    },
    "config": {
        "platform": {
            "php": "8.1"
        }
    }
}
